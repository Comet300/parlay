# =============================================================================
# Parlay — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Application ---
APP_BASE_URL=http://localhost:3000

# --- BetterAuth ---
BETTER_AUTH_SECRET=           # Random secret for BetterAuth session signing

# --- Google OAuth ---
GOOGLE_CLIENT_ID=             # From Google Cloud Console
GOOGLE_CLIENT_SECRET=         # From Google Cloud Console
# Callback URL: {APP_BASE_URL}/api/auth/callback/google

# --- Resend (transactional emails) ---
RESEND_API_KEY=               # From https://resend.com/api-keys

# --- Supabase ---
DATABASE_URL=                 # Direct PostgreSQL connection string (used by BetterAuth)
                              # Format: postgresql://postgres:[password]@[host]:5432/postgres
SUPABASE_URL=                 # Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_ANON_KEY=            # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=    # Supabase service role key (server-side only, never expose to client)
SUPABASE_JWT_SECRET=          # Supabase JWT secret (for signing bridged auth JWTs)
